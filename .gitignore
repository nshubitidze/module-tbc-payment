# Secrets / credentials — never commit
.env
.env.*
*.token
secrets/

# Build / runtime artifacts
/vendor/
/var/
/generated/
/composer.lock
.phpunit.cache/
.phpunit.result.cache

# IDE / OS
/.idea/
/.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Negate global ignores — this module ships its tests (open-source).
!Test/
!Test/**
