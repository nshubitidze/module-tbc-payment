<?xml version = "1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Sales::sales">
                    <resource id="Shubo_TbcPayment::tbc_payment" title="TBC Payment Actions" sortOrder="50">
                        <resource id="Shubo_TbcPayment::capture" title="Capture Payment" sortOrder="10"/>
                        <resource id="Shubo_TbcPayment::void" title="Void Payment" sortOrder="20"/>
                        <resource id="Shubo_TbcPayment::settle" title="Settle Payment" sortOrder="30"/>
                        <resource id="Shubo_TbcPayment::check_status" title="Check Payment Status" sortOrder="40"/>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
