<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Service contract binding -->
    <preference for="Shubo\TbcPayment\Api\Data\SplitPaymentDataInterface"
                type="Shubo\TbcPayment\Model\SplitPaymentData"/>

    <!-- Payment Method Facade -->
    <virtualType name="ShuboTbcPaymentFacade" type="Magento\Payment\Model\Method\Adapter">
        <arguments>
            <argument name="code" xsi:type="const">Shubo\TbcPayment\Model\Ui\ConfigProvider::CODE</argument>
            <argument name="formBlockType" xsi:type="string">Magento\Payment\Block\Form</argument>
            <argument name="infoBlockType" xsi:type="string">Shubo\TbcPayment\Block\Payment\Info</argument>
            <argument name="valueHandlerPool" xsi:type="object">ShuboTbcValueHandlerPool</argument>
            <argument name="commandPool" xsi:type="object">ShuboTbcCommandPool</argument>
        </arguments>
    </virtualType>

    <!-- Config reader -->
    <virtualType name="ShuboTbcPaymentConfig" type="Shubo\TbcPayment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">Shubo\TbcPayment\Model\Ui\ConfigProvider::CODE</argument>
        </arguments>
    </virtualType>

    <!-- Inject virtual config into all gateway classes -->
    <type name="Shubo\TbcPayment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">Shubo\TbcPayment\Model\Ui\ConfigProvider::CODE</argument>
        </arguments>
    </type>

    <!-- Value Handler Pool -->
    <virtualType name="ShuboTbcValueHandlerPool" type="Magento\Payment\Gateway\Config\ValueHandlerPool">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="string">ShuboTbcConfigValueHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <virtualType name="ShuboTbcConfigValueHandler" type="Magento\Payment\Gateway\Config\ConfigValueHandler">
        <arguments>
            <argument name="configInterface" xsi:type="object">ShuboTbcPaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Command Pool -->
    <virtualType name="ShuboTbcCommandPool" type="Magento\Payment\Gateway\Command\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="initialize" xsi:type="string">ShuboTbcInitializeCommand</item>
                <item name="refund" xsi:type="string">ShuboTbcRefundCommand</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Initialize Command (create Flitt checkout token) -->
    <virtualType name="ShuboTbcInitializeCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">ShuboTbcInitializeRequest</argument>
            <argument name="transferFactory" xsi:type="object">Shubo\TbcPayment\Gateway\Http\TransferFactory</argument>
            <argument name="client" xsi:type="object">Shubo\TbcPayment\Gateway\Http\Client\CreatePaymentClient</argument>
            <argument name="handler" xsi:type="object">Shubo\TbcPayment\Gateway\Response\InitializeHandler</argument>
            <argument name="validator" xsi:type="object">Shubo\TbcPayment\Gateway\Validator\ResponseValidator</argument>
        </arguments>
    </virtualType>

    <!-- Initialize Request Builder Composite -->
    <virtualType name="ShuboTbcInitializeRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="initialize" xsi:type="string">Shubo\TbcPayment\Gateway\Request\InitializeRequestBuilder</item>
                <item name="split_data" xsi:type="string">Shubo\TbcPayment\Gateway\Request\SplitDataBuilder</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Refund Command -->
    <virtualType name="ShuboTbcRefundCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">Shubo\TbcPayment\Gateway\Request\RefundRequestBuilder</argument>
            <argument name="transferFactory" xsi:type="object">Shubo\TbcPayment\Gateway\Http\TransferFactory</argument>
            <argument name="client" xsi:type="object">Shubo\TbcPayment\Gateway\Http\Client\RefundClient</argument>
            <argument name="handler" xsi:type="object">Shubo\TbcPayment\Gateway\Response\RefundHandler</argument>
        </arguments>
    </virtualType>

    <!-- Logger -->
    <virtualType name="ShuboTbcLogger" type="Magento\Payment\Model\Method\Logger">
        <arguments>
            <argument name="config" xsi:type="object">ShuboTbcPaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Inject logger virtual type where needed -->
    <type name="Shubo\TbcPayment\Gateway\Http\Client\CreatePaymentClient">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboTbcPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\TbcPayment\Gateway\Http\Client\RefundClient">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboTbcPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\TbcPayment\Controller\Payment\Callback">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboTbcPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\TbcPayment\Gateway\Validator\CallbackValidator">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboTbcPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\TbcPayment\Controller\Payment\Params">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboTbcPaymentLogger</argument>
        </arguments>
    </type>

    <!-- Dedicated log file for TBC payment -->
    <virtualType name="ShuboTbcPaymentLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">shubo_tbc_payment</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ShuboTbcPaymentLogHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <virtualType name="ShuboTbcPaymentLogHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/shubo_tbc_payment.log</argument>
        </arguments>
    </virtualType>
</config>
